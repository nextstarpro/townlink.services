            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/WorkSpace/new-project/node_modules/.pnpm/@capacitor+cli@5.7.8/node_modules/@capacitor/cli/node_modules:/mnt/d/WorkSpace/new-project/node_modules/.pnpm/@capacitor+cli@5.7.8/node_modules:/mnt/d/WorkSpace/new-project/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/WorkSpace/new-project/node_modules/.pnpm/@capacitor+cli@5.7.8/node_modules/@capacitor/cli/node_modules:/mnt/d/WorkSpace/new-project/node_modules/.pnpm/@capacitor+cli@5.7.8/node_modules:/mnt/d/WorkSpace/new-project/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../cli/bin/capacitor" "$@"
else
  exec node  "$basedir/../../../cli/bin/capacitor" "$@"
fi
