# TownLink Mobile App - Environment Variables Configuration

# Indicator that we are running inside the Capacitor static shell build
IS_CAPACITOR_BUILD=true

# API Endpoint pointing to the Netlify Serverless Functions
NEXT_PUBLIC_API_URL=http://localhost:8888/.netlify/functions

# Capgo Cloud configurations (Optional: For manual CLI operations if not logged in globally)
CAPGO_API_KEY=your_capgo_api_key_here
